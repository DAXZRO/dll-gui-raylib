{
 "version": "2.0.0",
 "tasks": [
  {
   "label": "Build Raylib",
   "type": "shell",
   "command": "gcc",
   "args": [
    "${file}",
    "-o",
    "${fileDirname}\\${fileBasenameNoExtension}.exe",
    "-Iraylib",
    "-Lraylib",
    "-lraylib",
    "-lopengl32",
    "-lgdi32",
    "-lwinmm"
   ],
   "group": {
    "kind": "build",
    "isDefault": true
   }
  }
 ]
}